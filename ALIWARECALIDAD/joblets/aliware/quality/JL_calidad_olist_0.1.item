    <node xmi:id="_I4fhmtmr_f1ih3ZEkOSPb_" componentName="tMap" posX="550" posY="350">
      <elementParameter field="TEXT" name="UNIQUE_NAME" value="tMap_2"></elementParameter>
      <elementParameter field="TEXT" name="LABEL" value="Calcular Score"></elementParameter>
      <metadata connector="FLOW" label="out_metrics" name="out_metrics" xmi:id="_rAJcj_PD5dv_iAiU3_UEao">
        <column name="run_id" type="id_String" nullable="true"></column>
        <column name="run_ts" type="id_Date" nullable="true"></column>
        <column name="dataset" type="id_String" nullable="true"></column>
        <column name="dimension" type="id_String" nullable="true"></column>
        <column name="rows_eval" type="id_Integer" nullable="true"></column>
        <column name="rows_ko" type="id_Integer" nullable="true"></column>
        <column name="score" type="id_Double" nullable="true"></column>
      </metadata>
      <nodeData xsi:type="TalendMapper:MapperData">
        <uiProperties shellMaximized="true"></uiProperties>
        <varTables sizeState="INTERMEDIATE" name="Var">
          <mapperTableEntries name="eval" expression="((Integer)globalMap.get(&quot;tDBInput_1_NB_LINE&quot;)) != null &amp;&amp; ((Integer)globalMap.get(&quot;tDBInput_1_NB_LINE&quot;)) &gt; 0 ? ((Integer)globalMap.get(&quot;tDBInput_1_NB_LINE&quot;)) : 1" type="id_Integer" nullable="false"></mapperTableEntries>
        </varTables>
        <outputTables sizeState="INTERMEDIATE" name="out_metrics">
          <mapperTableEntries name="run_id" expression="row_aggregated.run_id" type="id_String" nullable="true"></mapperTableEntries>
          <mapperTableEntries name="run_ts" expression="row_aggregated.run_ts" type="id_Date" nullable="true"></mapperTableEntries>
          <mapperTableEntries name="dataset" expression="row_aggregated.dataset" type="id_String" nullable="true"></mapperTableEntries>
          <mapperTableEntries name="dimension" expression="row_aggregated.dimension" type="id_String" nullable="true"></mapperTableEntries>
          <mapperTableEntries name="rows_eval" expression="Var.eval" type="id_Integer" nullable="true"></mapperTableEntries>
          <mapperTableEntries name="rows_ko" expression="row_aggregated.rows_ko" type="id_Integer" nullable="true"></mapperTableEntries>
          <mapperTableEntries name="score" expression="1 - ((double)row_aggregated.rows_ko / Var.eval)" type="id_Double" nullable="true"></mapperTableEntries>
        </outputTables>
        <inputTables sizeState="INTERMEDIATE" name="row_aggregated" matchingMode="ALL_ROWS" lookupMode="LOAD_ONCE">
          <mapperTableEntries name="run_id" type="id_String"></mapperTableEntries>
          <mapperTableEntries name="run_ts" type="id_Date"></mapperTableEntries>
          <mapperTableEntries name="dataset" type="id_String"></mapperTableEntries>
          <mapperTableEntries name="dimension" type="id_String"></mapperTableEntries>
          <mapperTableEntries name="rows_ko" type="id_Integer"></mapperTableEntries>
        </inputTables>
      </nodeData>
    </node>

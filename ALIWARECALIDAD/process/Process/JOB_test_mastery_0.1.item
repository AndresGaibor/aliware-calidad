  <node xmi:id="_lq4Ztkjqp7yzUUKkcfEGTy" componentName="tMap" posX="580" posY="240">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tMap_1"></elementParameter>
    <elementParameter field="TEXT" name="LABEL" value="Transformar"></elementParameter>
    <metadata connector="FLOW" label="row_mapped" name="row_mapped" xmi:id="_nVf7ZMDwNiL8veUvs0W-GY">
      <column name="id" type="id_Integer"></column>
      <column name="name" type="id_String"></column>
      <column name="value" type="id_Double"></column>
      <column name="total" type="id_Double"></column>
    </metadata>
    <nodeData xsi:type="TalendMapper:MapperData">
      <uiProperties shellMaximized="true"></uiProperties>
      <varTables sizeState="INTERMEDIATE" name="Var" minimized="true"></varTables>
      <outputTables sizeState="INTERMEDIATE" name="row_mapped">
        <mapperTableEntries name="id" expression="row_in.id" type="id_Integer"></mapperTableEntries>
        <mapperTableEntries name="name" expression="row_in.name.toUpperCase()" type="id_String"></mapperTableEntries>
        <mapperTableEntries name="value" expression="row_in.value" type="id_Double"></mapperTableEntries>
        <mapperTableEntries name="total" expression="row_in.value * 2" type="id_Double"></mapperTableEntries>
      </outputTables>
      <inputTables sizeState="INTERMEDIATE" name="row_in" matchingMode="ALL_ROWS" lookupMode="LOAD_ONCE">
        <mapperTableEntries name="id" type="id_Integer"></mapperTableEntries>
        <mapperTableEntries name="name" type="id_String"></mapperTableEntries>
        <mapperTableEntries name="value" type="id_Double"></mapperTableEntries>
      </inputTables>
    </nodeData>
  </node>

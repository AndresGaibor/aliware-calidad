  <node xmi:id="_hskyIYXEbfDcYw0weC8AZN" componentName="tMysqlInput" posX="400" posY="220">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBInput_1"></elementParameter>
    <elementParameter field="TEXT" name="LABEL" value="Leer tabla raw"></elementParameter>
    <elementParameter field="TEXT" name="USE_EXISTING_CONNECTION" value="true"></elementParameter>
    <elementParameter field="TEXT" name="CONNECTION" value="tDBConnection_1"></elementParameter>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT &apos;&quot; + ((String)globalMap.get(&quot;row1.dataset&quot;)) + &quot;&apos; AS dataset, t.* FROM raw.&quot; + ((String)globalMap.get(&quot;row1.dataset&quot;)) + &quot; t&quot;"></elementParameter>

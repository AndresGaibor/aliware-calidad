      <column name="row" type="id_Dynamic"></column>
    </metadata>
  </node>
  <node xmi:id="_BLr3M68av2G43iDI1IbPa2" componentName="tMap" posX="550" posY="220">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tMap_rules"></elementParameter>
    <elementParameter field="TEXT" name="LABEL" value="Evaluar DQ-001,002,004,005"></elementParameter>
    <metadata connector="FLOW" label="row_rules" name="row_rules" xmi:id="_KRBYSSCbtlFEKIOH9rdiyQ">
      <column name="run_id" type="id_String"></column>
      <column name="run_ts" type="id_Date"></column>
      <column name="dataset" type="id_String"></column>
      <column name="business_key" type="id_String"></column>
      <column name="payload_json" type="id_String"></column>
      <column name="rule_id" type="id_String"></column>
      <column name="dimension" type="id_String"></column>
      <column name="severity" type="id_String"></column>
      <column name="rule_passed" type="id_Boolean"></column>
    </metadata>
    <nodeData xsi:type="TalendMapper:MapperData">
      <uiProperties shellMaximized="true"></uiProperties>
      <varTables sizeState="INTERMEDIATE" name="Var">
        <mapperTableEntries name="datasetName" expression="((String)globalMap.get(&quot;row1.dataset&quot;))" type="id_String" nullable="false"></mapperTableEntries>
        <mapperTableEntries name="businessKey" expression="&quot;customers&quot;.equals(Var.datasetName) ? (row2.row.getColumnValue(&quot;customer_id&quot;) != null ? String.valueOf(row2.row.getColumnValue(&quot;customer_id&quot;)) : &quot;&quot;) : (row2.row.getColumnValue(&quot;order_id&quot;) != null ? String.valueOf(row2.row.getColumnValue(&quot;order_id&quot;)) : &quot;&quot;)" type="id_String" nullable="false"></mapperTableEntries>
        <mapperTableEntries name="payloadJson" expression="row2.row.toString()" type="id_String" nullable="false"></mapperTableEntries>
        <mapperTableEntries name="dq001_passed" expression="!(&quot;customers&quot;.equals(Var.datasetName) || &quot;orders&quot;.equals(Var.datasetName)) || (row2.row.getColumnValue(&quot;customer_id&quot;) != null &amp;&amp; !String.valueOf(row2.row.getColumnValue(&quot;customer_id&quot;)).trim().isEmpty())" type="id_Boolean"></mapperTableEntries>
        <mapperTableEntries name="dq002_passed" expression="!&quot;orders&quot;.equals(Var.datasetName) || java.util.Arrays.asList(&quot;delivered&quot;, &quot;shipped&quot;, &quot;canceled&quot;, &quot;unavailable&quot;, &quot;invoiced&quot;, &quot;processing&quot;, &quot;approved&quot;, &quot;created&quot;).contains(row2.row.getColumnValue(&quot;order_status&quot;) != null ? String.valueOf(row2.row.getColumnValue(&quot;order_status&quot;)) : &quot;&quot;)" type="id_Boolean"></mapperTableEntries>
        <mapperTableEntries name="dq004_passed" expression="!&quot;order_items&quot;.equals(Var.datasetName) || (row2.row.getColumnValue(&quot;price&quot;) != null &amp;&amp; Double.parseDouble(String.valueOf(row2.row.getColumnValue(&quot;price&quot;))) &gt; 0)" type="id_Boolean"></mapperTableEntries>
        <mapperTableEntries name="dq005_passed" expression="!&quot;orders&quot;.equals(Var.datasetName) || row2.row.getColumnValue(&quot;order_delivered_customer_date&quot;) == null || row2.row.getColumnValue(&quot;order_purchase_timestamp&quot;) == null || !((java.util.Date)row2.row.getColumnValue(&quot;order_delivered_customer_date&quot;)).before((java.util.Date)row2.row.getColumnValue(&quot;order_purchase_timestamp&quot;))" type="id_Boolean"></mapperTableEntries>
        <mapperTableEntries name="rulePassed" expression="Var.dq001_passed &amp;&amp; Var.dq002_passed &amp;&amp; Var.dq004_passed &amp;&amp; Var.dq005_passed" type="id_Boolean"></mapperTableEntries>
        <mapperTableEntries name="ruleId" expression="Var.rulePassed ? &quot;&quot; : (!Var.dq001_passed ? &quot;DQ-001&quot; : (!Var.dq002_passed ? &quot;DQ-002&quot; : (!Var.dq005_passed ? &quot;DQ-005&quot; : &quot;DQ-004&quot;)))" type="id_String"></mapperTableEntries>
        <mapperTableEntries name="dimension" expression="Var.rulePassed ? &quot;&quot; : (!Var.dq001_passed ? &quot;Completitud&quot; : (!Var.dq002_passed ? &quot;Validez&quot; : (!Var.dq005_passed ? &quot;Consistencia&quot; : &quot;Validez&quot;)))" type="id_String"></mapperTableEntries>
        <mapperTableEntries name="severity" expression="Var.rulePassed ? &quot;&quot; : (!Var.dq001_passed || !Var.dq002_passed ? &quot;Crítica&quot; : &quot;Alta&quot;)" type="id_String"></mapperTableEntries>
      </varTables>
      <outputTables sizeState="INTERMEDIATE" name="row_rules">
        <mapperTableEntries name="run_id" expression="context.run_id" type="id_String"></mapperTableEntries>
        <mapperTableEntries name="run_ts" expression="new java.util.Date()" type="id_Date"></mapperTableEntries>
        <mapperTableEntries name="dataset" expression="Var.datasetName" type="id_String"></mapperTableEntries>
        <mapperTableEntries name="business_key" expression="Var.businessKey" type="id_String"></mapperTableEntries>
        <mapperTableEntries name="payload_json" expression="Var.payloadJson" type="id_String"></mapperTableEntries>
        <mapperTableEntries name="rule_id" expression="Var.ruleId" type="id_String"></mapperTableEntries>
        <mapperTableEntries name="dimension" expression="Var.dimension" type="id_String"></mapperTableEntries>
        <mapperTableEntries name="severity" expression="Var.severity" type="id_String"></mapperTableEntries>
        <mapperTableEntries name="rule_passed" expression="Var.rulePassed" type="id_Boolean"></mapperTableEntries>
      </outputTables>
      <inputTables sizeState="INTERMEDIATE" name="row2" matchingMode="ALL_ROWS" lookupMode="LOAD_ONCE">
        <mapperTableEntries name="dataset" type="id_String"></mapperTableEntries>
        <mapperTableEntries name="row" type="id_Dynamic"></mapperTableEntries>
      </inputTables>
    </nodeData>
  </node>

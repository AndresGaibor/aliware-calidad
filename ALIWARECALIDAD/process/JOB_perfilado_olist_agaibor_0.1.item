  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="480" posY="120">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="output_row.dataset = input_row.dataset;&#xA;output_row.row = input_row.row;&#xA;&#xA;&#xA;System.out.println(&#xA;    &quot;Columnas Dynamic = &quot;&#xA;    + input_row.row.getColumnCount()&#xA;);&#xA;&#xA;for(int i=0; i&lt; input_row.row.getColumnCount(); i++)&#xA;{&#xA;    System.out.println(&#xA;        &quot;Columna: &quot;&#xA;        + input_row.row.getColumnMetadata(i).getName()&#xA;    );&#xA;}&#xA;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaRow_1">
      <column comment="" key="false" length="-1" name="dataset" nullable="true" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="row" nullable="true" pattern="&quot;dd-MM-yyyy&quot;" precision="-1" sourceType="" type="id_Dynamic" originalLength="-1" usefulColumn="true"/>
    </metadata>
  </node>
  <node componentName="tJavaFlex" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="640" posY="120">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaFlex_1" show="false"/>
    <elementParameter field="CHECK" name="DATA_AUTO_PROPAGATE" value="true"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_START" value="java.util.Map&lt;String, Long> totalRows =&#xA;new java.util.HashMap&lt;String, Long>();&#xA;&#xA;java.util.Map&lt;String, Long> nullRows =&#xA;new java.util.HashMap&lt;String, Long>();&#xA;&#xA;java.util.Map&lt;String, Long> totalChars =&#xA;new java.util.HashMap&lt;String, Long>();&#xA;&#xA;java.util.Map&lt;String, java.util.Set&lt;String>> distinctValues =&#xA;new java.util.HashMap&lt;String, java.util.Set&lt;String>>();&#xA;&#xA;java.util.Map&lt;String,String> dataTypes =&#xA;new java.util.HashMap&lt;String,String>();&#xA;&#xA;java.util.Map&lt;String,String> minValues =&#xA;new java.util.HashMap&lt;String,String>();&#xA;&#xA;java.util.Map&lt;String,String> maxValues =&#xA;new java.util.HashMap&lt;String,String>();"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_MAIN" value="routines.system.Dynamic dyn = input_row.row;&#xA;&#xA;//Dataset actual proveniente del tFlowToIterate&#xA;String datasetName =&#xA;(String)globalMap.get(&quot;row1.dataset&quot;);&#xA;&#xA;//Mostrar estructura sólo una vez&#xA;if(globalMap.get(&quot;PRINT_DYNAMIC_COLUMNS&quot;) == null)&#xA;{&#xA;System.out.println(&#xA;   &quot;Columnas Dynamic = &quot;&#xA;   + dyn.getColumnCount()&#xA;);&#xA;&#xA;for(int i = 0; i &lt; dyn.getColumnCount(); i++)&#xA;{&#xA;   System.out.println(&#xA;       &quot;Columna: &quot;&#xA;       + dyn.getColumnMetadata(i).getName()&#xA;   );&#xA;}&#xA;&#xA;globalMap.put(&#xA;   &quot;PRINT_DYNAMIC_COLUMNS&quot;,&#xA;   true&#xA;);&#xA;}&#xA;&#xA;//Recorrer todas las columnas dinámicas&#xA;for(int i = 0; i &lt; dyn.getColumnCount(); i++)&#xA;{&#xA;String columnName =&#xA;   dyn.getColumnMetadata(i)&#xA;      .getName()&#xA;      .replace(&quot;\&quot;&quot;,&quot;&quot;);&#xA;&#xA;Object value =&#xA;   dyn.getColumnValue(i);&#xA;&#xA;String key =&#xA;   datasetName&#xA;   + &quot;|&quot;&#xA;   + columnName;&#xA;&#xA;// ==========================&#xA;// Total registros&#xA;// ==========================&#xA;&#xA;totalRows.put(&#xA;   key,&#xA;   totalRows.getOrDefault(&#xA;       key,&#xA;       0L&#xA;   ) + 1&#xA;);&#xA;&#xA;// ==========================&#xA;// Nulos&#xA;// ==========================&#xA;&#xA;boolean isNull =&#xA;   (&#xA;       value == null&#xA;       ||&#xA;       String.valueOf(value)&#xA;             .trim()&#xA;             .isEmpty()&#xA;   );&#xA;&#xA;if(isNull)&#xA;{&#xA;   nullRows.put(&#xA;       key,&#xA;       nullRows.getOrDefault(&#xA;           key,&#xA;           0L&#xA;       ) + 1&#xA;   );&#xA;}&#xA;else&#xA;{&#xA;   String valueStr =&#xA;       String.valueOf(value);&#xA;&#xA;   // ==========================&#xA;   // Longitud acumulada&#xA;   // ==========================&#xA;&#xA;   totalChars.put(&#xA;       key,&#xA;       totalChars.getOrDefault(&#xA;           key,&#xA;           0L&#xA;       )&#xA;       +&#xA;       valueStr.length()&#xA;   );&#xA;&#xA;   // ==========================&#xA;   // Cardinalidad&#xA;   // ==========================&#xA;&#xA;   distinctValues&#xA;       .computeIfAbsent(&#xA;           key,&#xA;           k -> new java.util.HashSet&lt;String>()&#xA;       )&#xA;       .add(&#xA;           valueStr&#xA;       );&#xA;&#xA;   // ==========================&#xA;   // Tipo de dato observado&#xA;   // ==========================&#xA;&#xA;   dataTypes.putIfAbsent(&#xA;       key,&#xA;       value.getClass()&#xA;            .getSimpleName()&#xA;   );&#xA;&#xA;   // ==========================&#xA;   // Mínimo&#xA;   // ==========================&#xA;&#xA;   String currentMin =&#xA;       minValues.get(key);&#xA;&#xA;   if(&#xA;       currentMin == null&#xA;       ||&#xA;       valueStr.compareTo(&#xA;           currentMin&#xA;       ) &lt; 0&#xA;   )&#xA;   {&#xA;       minValues.put(&#xA;           key,&#xA;           valueStr&#xA;       );&#xA;   }&#xA;&#xA;   // ==========================&#xA;   // Máximo&#xA;   // ==========================&#xA;&#xA;   String currentMax =&#xA;       maxValues.get(key);&#xA;&#xA;   if(&#xA;       currentMax == null&#xA;       ||&#xA;       valueStr.compareTo(&#xA;           currentMax&#xA;       ) > 0&#xA;   )&#xA;   {&#xA;       maxValues.put(&#xA;           key,&#xA;           valueStr&#xA;       );&#xA;   }&#xA;}&#xA;}"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_END" value="for(String key : totalRows.keySet())&#xA;{&#xA;    Long total =&#xA;        totalRows.getOrDefault(key,0L);&#xA;&#xA;    Long nullCount =&#xA;        nullRows.getOrDefault(key,0L);&#xA;&#xA;    Long chars =&#xA;        totalChars.getOrDefault(key,0L);&#xA;&#xA;    Long cardinality =&#xA;        Long.valueOf(&#xA;            distinctValues&#xA;                .getOrDefault(&#xA;                    key,&#xA;                    new java.util.HashSet&lt;String>()&#xA;                )&#xA;                .size()&#xA;        );&#xA;&#xA;    Double avgLen =&#xA;        total == 0&#xA;        ? 0.0&#xA;        : ((double)chars / total);&#xA;&#xA;    System.out.println(&#xA;        key&#xA;        + &quot; | total=&quot;&#xA;        + total&#xA;        + &quot; | nulls=&quot;&#xA;        + nullCount&#xA;        + &quot; | cardinality=&quot;&#xA;        + cardinality&#xA;        + &quot; | avg_len=&quot;&#xA;        + avgLen&#xA;    );&#xA;}&#xA;"/>
    <elementParameter field="CHECK" name="Version_V2_0" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V3_2" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V4.0" value="true" show="false"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="import java.sql.Connection;&#xA;import java.sql.DriverManager;&#xA;import java.sql.PreparedStatement;&#xA;import java.sql.Timestamp;&#xA;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaFlex_1">

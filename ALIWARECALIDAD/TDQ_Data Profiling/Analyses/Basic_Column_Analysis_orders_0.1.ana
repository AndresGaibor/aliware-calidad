        <builtInIndicatorDefinition xmi:id="_r4xUYF6aEfGQ0ed-VkYKHg" name="Row Count" label="Row Count">
          <taggedValue xmi:id="_r4xUYV6aEfGQ0ed-VkYKHg" tag="Description" value="counts the number of rows"/>
          <taggedValue xmi:id="_r4xUYl6aEfGQ0ed-VkYKHg" tag="Purpose" value="evaluates the number of records"/>
          <sqlGenericExpression xmi:id="_r4xUY16aEfGQ0ed-VkYKHg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:NullCountIndicator" xmi:id="_rtOyy16aEfGQ0ed-VkYKHg" count="4589" computed="true">

      <indicators xsi:type="dataquality.indicators:PatternFreqIndicator" xmi:id="_rtPZ2F6aEfGQ0ed-VkYKHg" count="4589" computed="true" distinctValueCount="10" uniqueValueCount="4585" valueToFreq="">
        <parameters xmi:id="_rtPZ2V6aEfGQ0ed-VkYKHg"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/order_reviews_0.1.item#_EsLdRF6TEfGXp-igzKfSsw"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Pattern Frequency Statistics/Pattern_Frequency_Table_0.1.definition#_kQzTsJR-Ed2XO-JvLwVAwg"/>
        <builtInIndicatorDefinition xmi:id="_r48TgF6aEfGQ0ed-VkYKHg" name="Pattern Frequency Table" label="Pattern Frequency Table">
          <taggedValue xmi:id="_r48TgV6aEfGQ0ed-VkYKHg" tag="Description" value="counts the number of records for each distinct pattern"/>
          <taggedValue xmi:id="_r48Tgl6aEfGQ0ed-VkYKHg" tag="Purpose" value="evaluates the most frequent patterns"/>

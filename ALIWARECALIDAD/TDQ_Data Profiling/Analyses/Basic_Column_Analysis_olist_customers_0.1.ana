      <indicators xsi:type="dataquality.indicators:PatternFreqIndicator" xmi:id="_0w1TgF6VEfGXp-igzKfSsw" count="99441" computed="true" distinctValueCount="10" uniqueValueCount="99427" valueToFreq="">
        <parameters xmi:id="_0w1TgV6VEfGXp-igzKfSsw"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/customers_0.1.item#_V4mX416REfGXp-igzKfSsw"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Pattern Frequency Statistics/Pattern_Frequency_Table_0.1.definition#_kQzTsJR-Ed2XO-JvLwVAwg"/>
        <builtInIndicatorDefinition xmi:id="_3E5A0F6VEfGXp-igzKfSsw" name="Pattern Frequency Table" label="Pattern Frequency Table">
          <taggedValue xmi:id="_3E5A0V6VEfGXp-igzKfSsw" tag="Description" value="counts the number of records for each distinct pattern"/>
          <taggedValue xmi:id="_3E5A0l6VEfGXp-igzKfSsw" tag="Purpose" value="evaluates the most frequent patterns"/>
          <sqlGenericExpression xmi:id="_3E5A016VEfGXp-igzKfSsw" body="SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) c FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__GROUP_BY_ALIAS__%> ORDER BY c DESC" language="SQL"/>
          <sqlGenericExpression xmi:id="_3E5A1F6VEfGXp-igzKfSsw" body="SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) c FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__GROUP_BY_ALIAS__%> ORDER BY c DESC" language="MySQL"/>
          <sqlGenericExpression xmi:id="_3E5A1V6VEfGXp-igzKfSsw" body="SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) AS c FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> ORDER BY c DESC" language="Oracle"/>
          <sqlGenericExpression xmi:id="_3E5A1l6VEfGXp-igzKfSsw" body="SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) AS c FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__GROUP_BY_ALIAS__%> ORDER BY c DESC" language="PostgreSQL"/>

          <taggedValue xmi:id="_3FtgMl6VEfGXp-igzKfSsw" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_3FtgM16VEfGXp-igzKfSsw" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>

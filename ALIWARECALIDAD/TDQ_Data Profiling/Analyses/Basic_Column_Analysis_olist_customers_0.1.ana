        <builtInIndicatorDefinition xmi:id="_3E_HcF6VEfGXp-igzKfSsw" name="Null Count" label="Null Count">
          <taggedValue xmi:id="_3E_HcV6VEfGXp-igzKfSsw" tag="Purpose" value="evaluate the number of missing data (null records)"/>
          <taggedValue xmi:id="_3E_Hcl6VEfGXp-igzKfSsw" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_3E_Hc16VEfGXp-igzKfSsw" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>

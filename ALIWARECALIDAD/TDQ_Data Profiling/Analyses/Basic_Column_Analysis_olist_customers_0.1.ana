        <builtInIndicatorDefinition xmi:id="_3ExsEF6VEfGXp-igzKfSsw" name="Null Count" label="Null Count">
          <taggedValue xmi:id="_3ExsEV6VEfGXp-igzKfSsw" tag="Purpose" value="evaluate the number of missing data (null records)"/>
          <taggedValue xmi:id="_3ExsEl6VEfGXp-igzKfSsw" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_3ExsE16VEfGXp-igzKfSsw" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>

      <indicators xsi:type="dataquality.indicators:SoundexFreqIndicator" xmi:id="_0w3v8F6VEfGXp-igzKfSsw" count="99441" computed="true" distinctValueCount="10" uniqueValueCount="1144" valueToFreq="" valueToDistinctFreq="">

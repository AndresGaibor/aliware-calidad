          <taggedValue xmi:id="_Wyj9Yl6fEfGQ0ed-VkYKHg" tag="Purpose" value="evaluates the number of records"/>
          <sqlGenericExpression xmi:id="_Wyj9Y16fEfGQ0ed-VkYKHg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>

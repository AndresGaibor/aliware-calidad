          <taggedValue xmi:id="_Wyd2wV6fEfGQ0ed-VkYKHg" tag="Purpose" value="evaluate the number of missing data (null records)"/>
          <taggedValue xmi:id="_Wyd2wl6fEfGQ0ed-VkYKHg" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_Wyd2w16fEfGQ0ed-VkYKHg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>

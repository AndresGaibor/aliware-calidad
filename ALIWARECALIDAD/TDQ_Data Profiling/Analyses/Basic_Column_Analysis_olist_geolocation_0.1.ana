      <indicators xsi:type="dataquality.indicators:PatternFreqIndicator" xmi:id="_oUvUXF6XEfGXp-igzKfSsw" count="1000163" computed="true" distinctValueCount="1" uniqueValueCount="0" valueToFreq="">
        <parameters xmi:id="_oUvUXV6XEfGXp-igzKfSsw"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/geolocation_0.1.item#_3zZ0AV6SEfGXp-igzKfSsw"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Pattern Frequency Statistics/Pattern_Frequency_Table_0.1.definition#_kQzTsJR-Ed2XO-JvLwVAwg"/>
        <builtInIndicatorDefinition xmi:id="_ofvDYF6XEfGXp-igzKfSsw" name="Pattern Frequency Table" label="Pattern Frequency Table">
          <taggedValue xmi:id="_ofvDYV6XEfGXp-igzKfSsw" tag="Description" value="counts the number of records for each distinct pattern"/>
          <taggedValue xmi:id="_ofvDYl6XEfGXp-igzKfSsw" tag="Purpose" value="evaluates the most frequent patterns"/>
          <sqlGenericExpression xmi:id="_ofvDY16XEfGXp-igzKfSsw" body="SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) c FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__GROUP_BY_ALIAS__%> ORDER BY c DESC" language="SQL"/>

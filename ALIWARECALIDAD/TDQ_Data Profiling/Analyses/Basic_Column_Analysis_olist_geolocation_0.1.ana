        <builtInIndicatorDefinition xmi:id="_ofqx8F6XEfGXp-igzKfSsw" name="Distinct Count" label="Distinct Count">
          <taggedValue xmi:id="_ofqx8V6XEfGXp-igzKfSsw" tag="Description" value="counts the number of distinct rows (like a &quot;SELECT DISTINCT&quot; SQL statement)"/>
          <taggedValue xmi:id="_ofqx8l6XEfGXp-igzKfSsw" tag="Purpose" value="evaluates the number of distinct records"/>
          <sqlGenericExpression xmi:id="_ofqx816XEfGXp-igzKfSsw" body="SELECT COUNT(*) FROM (SELECT DISTINCT &lt;%=__COLUMN_NAMES__%> FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>) A" language="SQL"/>

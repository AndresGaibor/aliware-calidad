          <taggedValue xmi:id="_ogFosV6XEfGXp-igzKfSsw" tag="Purpose" value="evaluate the number of missing data (null records)"/>
          <taggedValue xmi:id="_ogFosl6XEfGXp-igzKfSsw" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_ogFos16XEfGXp-igzKfSsw" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:DistinctCountIndicator" xmi:id="_oUv7fF6XEfGXp-igzKfSsw" count="1000163" computed="true" distinctValueCount="8010">
        <parameters xmi:id="_oUv7fV6XEfGXp-igzKfSsw"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/geolocation_0.1.item#_3zZ0BF6SEfGXp-igzKfSsw"/>

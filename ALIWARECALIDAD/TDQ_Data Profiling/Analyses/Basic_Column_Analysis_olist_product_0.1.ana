          <taggedValue xmi:id="_yiQ-ol6fEfGQ0ed-VkYKHg" tag="Purpose" value="evaluates the number of records"/>
          <sqlGenericExpression xmi:id="_yiQ-o16fEfGQ0ed-VkYKHg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>

      <indicators xsi:type="dataquality.indicators:RowCountIndicator" xmi:id="_yWnIk16fEfGQ0ed-VkYKHg" count="32951" computed="true">
        <parameters xmi:id="_yWnIlF6fEfGQ0ed-VkYKHg"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/products_0.1.item#_Qr2jqVR0EfG4b6yKTmlQGQ"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Row_Count_0.1.definition#_ccFOkBF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_yitDgF6fEfGQ0ed-VkYKHg" name="Row Count" label="Row Count">
          <taggedValue xmi:id="_yitDgV6fEfGQ0ed-VkYKHg" tag="Description" value="counts the number of rows"/>
          <taggedValue xmi:id="_yitDgl6fEfGQ0ed-VkYKHg" tag="Purpose" value="evaluates the number of records"/>
          <sqlGenericExpression xmi:id="_yitDg16fEfGQ0ed-VkYKHg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:NullCountIndicator" xmi:id="_yWnvUF6fEfGQ0ed-VkYKHg" count="32951" nullCount="2" computed="true">
        <parameters xmi:id="_yWnvUV6fEfGQ0ed-VkYKHg"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/products_0.1.item#_Qr2jqVR0EfG4b6yKTmlQGQ"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Null_Count_0.1.definition#_GrAeADh9Ed2XmO7pl5Yuyg"/>
        <builtInIndicatorDefinition xmi:id="_yiuRoF6fEfGQ0ed-VkYKHg" name="Null Count" label="Null Count">
          <taggedValue xmi:id="_yiuRoV6fEfGQ0ed-VkYKHg" tag="Purpose" value="evaluate the number of missing data (null records)"/>
          <taggedValue xmi:id="_yiuRol6fEfGQ0ed-VkYKHg" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_yiuRo16fEfGQ0ed-VkYKHg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:DistinctCountIndicator" xmi:id="_yWnvUl6fEfGQ0ed-VkYKHg" count="32951" nullCount="2" computed="true" distinctValueCount="100">
        <parameters xmi:id="_yWnvU16fEfGQ0ed-VkYKHg"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/products_0.1.item#_Qr2jqVR0EfG4b6yKTmlQGQ"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Distinct_Count_0.1.definition#_ccHq0BF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_yiwG0F6fEfGQ0ed-VkYKHg" name="Distinct Count" label="Distinct Count">
          <taggedValue xmi:id="_yiwG0V6fEfGQ0ed-VkYKHg" tag="Description" value="counts the number of distinct rows (like a &quot;SELECT DISTINCT&quot; SQL statement)"/>
          <taggedValue xmi:id="_yiwG0l6fEfGQ0ed-VkYKHg" tag="Purpose" value="evaluates the number of distinct records"/>
          <sqlGenericExpression xmi:id="_yiwG016fEfGQ0ed-VkYKHg" body="SELECT COUNT(*) FROM (SELECT DISTINCT &lt;%=__COLUMN_NAMES__%> FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>) A" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>

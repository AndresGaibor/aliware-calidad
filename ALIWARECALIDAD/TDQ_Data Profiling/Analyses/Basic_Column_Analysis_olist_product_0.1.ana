        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/products_0.1.item#_Qr2jpFR0EfG4b6yKTmlQGQ"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Row_Count_0.1.definition#_ccFOkBF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_yh_R0F6fEfGQ0ed-VkYKHg" name="Row Count" label="Row Count">
          <taggedValue xmi:id="_yh_R0V6fEfGQ0ed-VkYKHg" tag="Description" value="counts the number of rows"/>
          <taggedValue xmi:id="_yh_R0l6fEfGQ0ed-VkYKHg" tag="Purpose" value="evaluates the number of records"/>
          <sqlGenericExpression xmi:id="_yh_R016fEfGQ0ed-VkYKHg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:NullCountIndicator" xmi:id="_yWnIUl6fEfGQ0ed-VkYKHg" count="32951" computed="true">

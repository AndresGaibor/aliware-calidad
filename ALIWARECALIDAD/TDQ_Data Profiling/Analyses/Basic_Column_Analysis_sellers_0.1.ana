        <builtInIndicatorDefinition xmi:id="_I0XHsF6gEfGQ0ed-VkYKHg" name="Pattern Frequency Table" label="Pattern Frequency Table">
          <taggedValue xmi:id="_I0XHsV6gEfGQ0ed-VkYKHg" tag="Description" value="counts the number of records for each distinct pattern"/>
          <taggedValue xmi:id="_I0XHsl6gEfGQ0ed-VkYKHg" tag="Purpose" value="evaluates the most frequent patterns"/>

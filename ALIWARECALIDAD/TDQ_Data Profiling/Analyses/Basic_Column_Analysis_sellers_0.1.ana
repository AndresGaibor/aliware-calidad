      <indicators xsi:type="dataquality.indicators:MinLengthIndicator" xmi:id="_Ioq1Fl6gEfGQ0ed-VkYKHg" count="99441" computed="true" length="32">
        <parameters xmi:id="_Ioq1F16gEfGQ0ed-VkYKHg">
          <textParameter xmi:id="_Ioq1GF6gEfGQ0ed-VkYKHg" useBlank="false"/>

      <indicators xsi:type="dataquality.indicators:PatternFreqIndicator" xmi:id="_IorcVF6gEfGQ0ed-VkYKHg" count="99441" nullCount="1783" computed="true" distinctValueCount="2" uniqueValueCount="0" valueToFreq="">
        <parameters xmi:id="_IorcVV6gEfGQ0ed-VkYKHg"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/orders_0.1.item#_JhcN916REfGXp-igzKfSsw"/>

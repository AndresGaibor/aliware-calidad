      <indicators xsi:type="dataquality.indicators:PatternFreqIndicator" xmi:id="_bruWoF6dEfGQ0ed-VkYKHg" count="112650" computed="true" distinctValueCount="10" uniqueValueCount="88841" valueToFreq="">
        <parameters xmi:id="_bruWoV6dEfGQ0ed-VkYKHg"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/order_items_0.1.item#_PpzC5FX3EfGBwpuyyuDaVg"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Pattern Frequency Statistics/Pattern_Frequency_Table_0.1.definition#_kQzTsJR-Ed2XO-JvLwVAwg"/>
        <builtInIndicatorDefinition xmi:id="_b5IggF6dEfGQ0ed-VkYKHg" name="Pattern Frequency Table" label="Pattern Frequency Table">
          <taggedValue xmi:id="_b5IggV6dEfGQ0ed-VkYKHg" tag="Description" value="counts the number of records for each distinct pattern"/>
          <taggedValue xmi:id="_b5Iggl6dEfGQ0ed-VkYKHg" tag="Purpose" value="evaluates the most frequent patterns"/>

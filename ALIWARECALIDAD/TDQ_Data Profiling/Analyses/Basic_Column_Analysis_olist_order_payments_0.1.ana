        <builtInIndicatorDefinition xmi:id="_1xPuAF6dEfGQ0ed-VkYKHg" name="Pattern Frequency Table" label="Pattern Frequency Table">
          <taggedValue xmi:id="_1xPuAV6dEfGQ0ed-VkYKHg" tag="Description" value="counts the number of records for each distinct pattern"/>
          <taggedValue xmi:id="_1xPuAl6dEfGQ0ed-VkYKHg" tag="Purpose" value="evaluates the most frequent patterns"/>

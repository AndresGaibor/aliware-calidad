    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_START" value="java.util.Map&lt;String, Long> envTotalRows = (java.util.Map&lt;String, Long>) globalMap.get(&quot;totalRows&quot;);&#xD;&#xA;java.util.Map&lt;String, Long> envNullRows = (java.util.Map&lt;String, Long>) globalMap.get(&quot;nullRows&quot;);&#xD;&#xA;java.util.Map&lt;String, Long> envTotalChars = (java.util.Map&lt;String, Long>) globalMap.get(&quot;totalChars&quot;);&#xD;&#xA;java.util.Map&lt;String, java.util.Set&lt;String>> envDistinctValues = (java.util.Map&lt;String, java.util.Set&lt;String>>) globalMap.get(&quot;distinctValues&quot;);&#xD;&#xA;java.util.Map&lt;String, String> envDataTypes = (java.util.Map&lt;String, String>) globalMap.get(&quot;dataTypes&quot;);&#xD;&#xA;java.util.Map&lt;String, String> envMinValues = (java.util.Map&lt;String, String>) globalMap.get(&quot;minValues&quot;);&#xD;&#xA;java.util.Map&lt;String, String> envMaxValues = (java.util.Map&lt;String, String>) globalMap.get(&quot;maxValues&quot;);&#xD;&#xA;java.util.Map&lt;String, java.util.Map&lt;String, Long>> patternCounts =&#xD;&#xA;(java.util.Map&lt;String, java.util.Map&lt;String, Long>>) globalMap.get(&quot;DQ_PATTERN_COUNTS&quot;);&#xD;&#xA;for(String key : envTotalRows.keySet()) {&#xA;"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_MAIN" value="String[] parts = key.split(&quot;\\|&quot;);&#xD;&#xA;&#xD;&#xA;output_row.dataset = parts[0];&#xD;&#xA;output_row.column_name = parts[1];&#xD;&#xA;&#xD;&#xA;output_row.rows_total = envTotalRows.getOrDefault(key, 0L);&#xD;&#xA;output_row.rows_null = envNullRows.getOrDefault(key, 0L);&#xD;&#xA;output_row.data_type = envDataTypes.getOrDefault(key, &quot;String&quot;);&#xD;&#xA;&#xD;&#xA;output_row.cardinality = Long.valueOf(envDistinctValues.getOrDefault(key, new java.util.HashSet&lt;String>()).size());&#xD;&#xA;output_row.min_val = envMinValues.get(key);&#xD;&#xA;output_row.max_val = envMaxValues.get(key);&#xD;&#xA;&#xD;&#xA;Long total = envTotalRows.getOrDefault(key, 0L);&#xD;&#xA;Long chars = envTotalChars.getOrDefault(key, 0L);&#xD;&#xA;output_row.avg_len = (total == 0) ? 0.0 : ((double)chars / total);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;String patternTop =&#xD;&#xA;null;&#xD;&#xA;&#xD;&#xA;Long patternTopCount =&#xD;&#xA;0L;&#xD;&#xA;&#xD;&#xA;java.util.Map&lt;String, Long> patterns =&#xD;&#xA;patternCounts.get(key);&#xD;&#xA;&#xD;&#xA;if (patterns != null) {&#xD;&#xA;&#xD;&#xA;for (java.util.Map.Entry&lt;String, Long> entry : patterns.entrySet()) {&#xD;&#xA;&#xD;&#xA;    if (entry.getValue() > patternTopCount) {&#xD;&#xA;        patternTop = entry.getKey();&#xD;&#xA;        patternTopCount = entry.getValue();&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;Long nullCount = envNullRows.getOrDefault(key, 0L);&#xD;&#xA;&#xD;&#xA;Long nonNull =&#xD;&#xA;total - nullCount;&#xD;&#xA;&#xD;&#xA;Double pctTop =&#xD;&#xA;nonNull == 0&#xD;&#xA;? 0.0&#xD;&#xA;: ((double) patternTopCount * 100.0) / nonNull;&#xD;&#xA;row5.pattern_top = patternTop;&#xD;&#xA;row5.pct_top = pctTop;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_END" value="}"/>

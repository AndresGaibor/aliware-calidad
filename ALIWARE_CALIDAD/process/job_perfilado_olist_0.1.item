  <node componentName="tJavaFlex" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="600" posY="40">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaFlex_1" show="false"/>
    <elementParameter field="CHECK" name="DATA_AUTO_PROPAGATE" value="true"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_START" value="&#xD;&#xA;java.util.Map&lt;String, Long> totalRows = new java.util.HashMap&lt;String, Long>();&#xD;&#xA;java.util.Map&lt;String, Long> nullRows = new java.util.HashMap&lt;String, Long>();&#xD;&#xA;java.util.Map&lt;String, Long> totalChars = new java.util.HashMap&lt;String, Long>();&#xD;&#xA;java.util.Map&lt;String, java.util.Set&lt;String>> distinctValues = new java.util.HashMap&lt;String, java.util.Set&lt;String>>();&#xD;&#xA;java.util.Map&lt;String, String> dataTypes = new java.util.HashMap&lt;String, String>();&#xD;&#xA;java.util.Map&lt;String, String> minValues = new java.util.HashMap&lt;String, String>();&#xD;&#xA;java.util.Map&lt;String, java.util.Map&lt;String, Long>> valueFrequencies = new java.util.HashMap&lt;String, java.util.Map&lt;String, Long>>();&#xD;&#xA;java.util.Map&lt;String, String> maxValues = new java.util.HashMap&lt;String, String>();&#xD;&#xA;java.util.Map&lt;String, java.util.Map&lt;String, Long>> patternCounts = new java.util.HashMap&lt;String, java.util.Map&lt;String, Long>>();"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_MAIN" value="routines.system.Dynamic dyn = input_row.row;&#xD;&#xA;String datasetName = (String)globalMap.get(&quot;row1.dataset&quot;);&#xD;&#xA;&#xD;&#xA;for(int i = 0; i &lt; dyn.getColumnCount(); i++) {&#xD;&#xA;    String columnName = dyn.getColumnMetadata(i).getName().replace(&quot;\&quot;&quot;, &quot;&quot;);&#xD;&#xA;    Object value = dyn.getColumnValue(i);&#xD;&#xA;    String key = datasetName + &quot;|&quot; + columnName;&#xD;&#xA;&#xD;&#xA;    // Acumular Totales&#xD;&#xA;    totalRows.put(key, totalRows.getOrDefault(key, 0L) + 1L);&#xD;&#xA;&#xD;&#xA;    // Contar Nulos&#xD;&#xA;    boolean isNull = (value == null || String.valueOf(value).trim().isEmpty());&#xD;&#xA;    if(isNull) {&#xD;&#xA;        nullRows.put(key, nullRows.getOrDefault(key, 0L) + 1L);&#xD;&#xA;    } else {&#xD;&#xA;        String valueStr = String.valueOf(value);&#xD;&#xA;        &#xD;&#xA;        // Acumular Longitud para el promedio&#xD;&#xA;        totalChars.put(key, totalChars.getOrDefault(key, 0L) + valueStr.length());&#xD;&#xA;        &#xD;&#xA;        // Guardar para Cardinalidad (valores únicos)&#xD;&#xA;        distinctValues.computeIfAbsent(key, k -> new java.util.HashSet&lt;String>()).add(valueStr);&#xD;&#xA;        &#xD;&#xA;        // Guardar Tipo de Dato&#xD;&#xA;     // ==========================&#xD;&#xA;     // Inferencia de Tipo de Dato&#xD;&#xA;     // ==========================&#xD;&#xA;     String inferredType = &quot;String&quot;;&#xD;&#xA;&#xD;&#xA;     // Si solo contiene números (opcionalmente un signo menos al inicio)&#xD;&#xA;     if (valueStr.matches(&quot;-?\\d+&quot;)) {&#xD;&#xA;         inferredType = &quot;Long&quot;;&#xD;&#xA;     } &#xD;&#xA;     // Si contiene números y un punto decimal&#xD;&#xA;     else if (valueStr.matches(&quot;-?\\d+\\.\\d+&quot;)) {&#xD;&#xA;         inferredType = &quot;Double&quot;;&#xD;&#xA;     } &#xD;&#xA;     // Si tiene formato de fecha estándar (ej. YYYY-MM-DD o DD/MM/YYYY)&#xD;&#xA;     else if (valueStr.matches(&quot;\\d{4}-\\d{2}-\\d{2}.*&quot;) || valueStr.matches(&quot;\\d{2}/\\d{2}/\\d{4}.*&quot;)) {&#xD;&#xA;         inferredType = &quot;Date&quot;;&#xD;&#xA;     }&#xD;&#xA;&#xD;&#xA;     // Jerarquía de tipos: Evaluamos si ya existía un tipo previo para esta columna&#xD;&#xA;     String currentType = dataTypes.get(key);&#xD;&#xA;&#xD;&#xA;     if (currentType == null) {&#xD;&#xA;         // Si es el primer registro que leemos, le asignamos el tipo detectado&#xD;&#xA;         dataTypes.put(key, inferredType);&#xD;&#xA;     } else if (!currentType.equals(&quot;String&quot;)) {&#xD;&#xA;         // Si detectamos letras en una columna que creíamos numérica, toda la columna pasa a ser String&#xD;&#xA;         if (inferredType.equals(&quot;String&quot;)) {&#xD;&#xA;             dataTypes.put(key, &quot;String&quot;);&#xD;&#xA;         } &#xD;&#xA;         // Si creíamos que era entero pero cae un decimal, la columna pasa a ser Double&#xD;&#xA;         else if (currentType.equals(&quot;Long&quot;) &amp;&amp; inferredType.equals(&quot;Double&quot;)) {&#xD;&#xA;             dataTypes.put(key, &quot;Double&quot;);&#xD;&#xA;         }&#xD;&#xA;     }&#xD;&#xA;        &#xD;&#xA;        &#xD;&#xA;        // Evaluar Mínimo&#xD;&#xA;        String currentMin = minValues.get(key);&#xD;&#xA;        if(currentMin == null || valueStr.compareTo(currentMin) &lt; 0) {&#xD;&#xA;            minValues.put(key, valueStr);&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Evaluar Máximo&#xD;&#xA;        String currentMax = maxValues.get(key);&#xD;&#xA;        if(currentMax == null || valueStr.compareTo(currentMax) > 0) {&#xD;&#xA;            maxValues.put(key, valueStr);&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        String pattern =&#xD;&#xA;                valueStr&#xD;&#xA;                    .replaceAll(&quot;[0-9]&quot;, &quot;9&quot;)&#xD;&#xA;                    .replaceAll(&quot;[A-ZÁÉÍÓÚÑ]&quot;, &quot;A&quot;)&#xD;&#xA;                    .replaceAll(&quot;[a-záéíóúñ]&quot;, &quot;a&quot;)&#xD;&#xA;                    .replaceAll(&quot;\\s&quot;, &quot; &quot;);&#xD;&#xA;&#xD;&#xA;            patternCounts&#xD;&#xA;                .computeIfAbsent(&#xD;&#xA;                    key,&#xD;&#xA;                    k -> new java.util.HashMap&lt;String, Long>()&#xD;&#xA;                )&#xD;&#xA;                .put(&#xD;&#xA;                    pattern,&#xD;&#xA;                    patternCounts&#xD;&#xA;                        .get(key)&#xD;&#xA;                        .getOrDefault(pattern, 0L) + 1&#xD;&#xA;                );&#xD;&#xA;    }&#xD;&#xA;}"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_END" value="globalMap.put(&quot;totalRows&quot;, totalRows);&#xD;&#xA;globalMap.put(&quot;nullRows&quot;, nullRows);&#xD;&#xA;globalMap.put(&quot;totalChars&quot;, totalChars);&#xD;&#xA;globalMap.put(&quot;distinctValues&quot;, distinctValues);&#xD;&#xA;globalMap.put(&quot;dataTypes&quot;, dataTypes);&#xD;&#xA;globalMap.put(&quot;minValues&quot;, minValues);&#xD;&#xA;globalMap.put(&quot;maxValues&quot;, maxValues);&#xD;&#xA;globalMap.put(&quot;DQ_PATTERN_COUNTS&quot;, patternCounts);"/>
    <elementParameter field="CHECK" name="Version_V2_0" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V3_2" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V4.0" value="true" show="false"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;&#xA;import java.sql.Connection;&#xA;import java.sql.DriverManager;&#xA;import java.sql.PreparedStatement;&#xA;import java.sql.Timestamp;&#xD;&#xA;&#xD;&#xA;&#xA;"/>

          <taggedValue xmi:id="_27tEEl6fEfGmeMsHSxupsg" tag="Purpose" value="evaluates the number of records"/>
          <sqlGenericExpression xmi:id="_27tEE16fEfGmeMsHSxupsg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>

      <indicators xsi:type="dataquality.indicators:RowCountIndicator" xmi:id="_2kEnQF6fEfGmeMsHSxupsg" count="32951" computed="true">
        <parameters xmi:id="_2kEnQV6fEfGmeMsHSxupsg"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/products_0.1.item#_JiaMZV6TEfGmeMsHSxupsg"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Row_Count_0.1.definition#_ccFOkBF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_2zkbwF6fEfGmeMsHSxupsg" name="Row Count" label="Row Count">
          <taggedValue xmi:id="_2zkbwV6fEfGmeMsHSxupsg" tag="Description" value="counts the number of rows"/>
          <taggedValue xmi:id="_2zkbwl6fEfGmeMsHSxupsg" tag="Purpose" value="evaluates the number of records"/>
          <sqlGenericExpression xmi:id="_2zkbw16fEfGmeMsHSxupsg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:NullCountIndicator" xmi:id="_2kEnQl6fEfGmeMsHSxupsg" count="32951" computed="true">
        <parameters xmi:id="_2kEnQ16fEfGmeMsHSxupsg"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/products_0.1.item#_JiaMZV6TEfGmeMsHSxupsg"/>

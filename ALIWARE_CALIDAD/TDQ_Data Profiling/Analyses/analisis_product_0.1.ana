          <taggedValue xmi:id="_274DMl6fEfGmeMsHSxupsg" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_274DM16fEfGmeMsHSxupsg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:DistinctCountIndicator" xmi:id="_2kEnoV6fEfGmeMsHSxupsg" count="32951" nullCount="2" computed="true" distinctValueCount="96">

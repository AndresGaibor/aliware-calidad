      <indicators xsi:type="dataquality.indicators:MinLengthIndicator" xmi:id="_0PbPsl6VEfGmeMsHSxupsg" count="99441" computed="true" length="2">
        <parameters xmi:id="_0PbPs16VEfGmeMsHSxupsg">
          <textParameter xmi:id="_0PbPtF6VEfGmeMsHSxupsg" useBlank="false"/>
        </parameters>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/customers_0.1.item#_5ii2aF6SEfGmeMsHSxupsg"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Text Statistics/Minimal_Length_0.1.definition#_ccHq1BF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_3vEmQF6VEfGmeMsHSxupsg" name="Minimal Length" label="Minimal Length">
          <taggedValue xmi:id="_3vEmQV6VEfGmeMsHSxupsg" tag="Description" value="computes the minimal length of a text field. Does not take into account the null and blank values when computing the minimal length."/>

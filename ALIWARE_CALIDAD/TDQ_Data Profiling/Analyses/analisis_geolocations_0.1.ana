      <indicators xsi:type="dataquality.indicators:PatternFreqIndicator" xmi:id="_rloLbF6ZEfGmeMsHSxupsg" count="1000163" computed="true" distinctValueCount="1" uniqueValueCount="0" valueToFreq="">

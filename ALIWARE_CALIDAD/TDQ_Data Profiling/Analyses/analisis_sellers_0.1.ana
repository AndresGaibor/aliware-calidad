        <builtInIndicatorDefinition xmi:id="_UivaYF6gEfGmeMsHSxupsg" name="Null Count" label="Null Count">
          <taggedValue xmi:id="_UivaYV6gEfGmeMsHSxupsg" tag="Purpose" value="evaluate the number of missing data (null records)"/>
          <taggedValue xmi:id="_UivaYl6gEfGmeMsHSxupsg" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_UivaY16gEfGmeMsHSxupsg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:DistinctCountIndicator" xmi:id="_UVclVl6gEfGmeMsHSxupsg" count="3095" computed="true" distinctValueCount="2246">

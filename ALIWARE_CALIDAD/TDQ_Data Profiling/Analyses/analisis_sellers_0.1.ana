      <indicators xsi:type="dataquality.indicators:MinLengthIndicator" xmi:id="_UVclaV6gEfGmeMsHSxupsg" count="3095" computed="true" length="2">
        <parameters xmi:id="_UVclal6gEfGmeMsHSxupsg">
          <textParameter xmi:id="_UVcla16gEfGmeMsHSxupsg" useBlank="false"/>
        </parameters>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/sellers_0.1.item#_wbeuxV6TEfGmeMsHSxupsg"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Text Statistics/Minimal_Length_0.1.definition#_ccHq1BF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_UkJvoF6gEfGmeMsHSxupsg" name="Minimal Length" label="Minimal Length">
          <taggedValue xmi:id="_UkJvoV6gEfGmeMsHSxupsg" tag="Description" value="computes the minimal length of a text field. Does not take into account the null and blank values when computing the minimal length."/>

      <indicators xsi:type="dataquality.indicators:SoundexFreqIndicator" xmi:id="_UVclTl6gEfGmeMsHSxupsg" count="3095" computed="true" distinctValueCount="10" uniqueValueCount="3095" valueToFreq="" valueToDistinctFreq="">
        <parameters xmi:id="_UVclT16gEfGmeMsHSxupsg"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/OLIST/sellers_0.1.item#_wbeuw16TEfGmeMsHSxupsg"/>

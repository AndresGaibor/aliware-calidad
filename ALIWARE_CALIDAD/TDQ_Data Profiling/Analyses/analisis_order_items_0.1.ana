        <builtInIndicatorDefinition xmi:id="_SKbmkF6dEfGmeMsHSxupsg" name="Distinct Count" label="Distinct Count">
          <taggedValue xmi:id="_SKbmkV6dEfGmeMsHSxupsg" tag="Description" value="counts the number of distinct rows (like a &quot;SELECT DISTINCT&quot; SQL statement)"/>
          <taggedValue xmi:id="_SKbmkl6dEfGmeMsHSxupsg" tag="Purpose" value="evaluates the number of distinct records"/>
          <sqlGenericExpression xmi:id="_SKbmk16dEfGmeMsHSxupsg" body="SELECT COUNT(*) FROM (SELECT DISTINCT &lt;%=__COLUMN_NAMES__%> FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>) A" language="SQL"/>
        </builtInIndicatorDefinition>

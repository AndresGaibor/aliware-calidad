        <builtInIndicatorDefinition xmi:id="__17CgF6eEfGmeMsHSxupsg" name="Pattern Frequency Table" label="Pattern Frequency Table">
          <taggedValue xmi:id="__17CgV6eEfGmeMsHSxupsg" tag="Description" value="counts the number of records for each distinct pattern"/>
          <taggedValue xmi:id="__17Cgl6eEfGmeMsHSxupsg" tag="Purpose" value="evaluates the most frequent patterns"/>
          <sqlGenericExpression xmi:id="__17Cg16eEfGmeMsHSxupsg" body="SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) c FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__GROUP_BY_ALIAS__%> ORDER BY c DESC" language="SQL"/>

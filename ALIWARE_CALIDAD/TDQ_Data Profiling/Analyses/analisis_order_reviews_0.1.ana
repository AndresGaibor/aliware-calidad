          <taggedValue xmi:id="__1Oe8l6eEfGmeMsHSxupsg" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="__1Oe816eEfGmeMsHSxupsg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>

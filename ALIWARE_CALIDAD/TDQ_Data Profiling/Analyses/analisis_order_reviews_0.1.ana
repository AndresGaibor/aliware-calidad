          <taggedValue xmi:id="__1FVAl6eEfGmeMsHSxupsg" tag="Purpose" value="evaluates the number of records"/>
          <sqlGenericExpression xmi:id="__1FVA16eEfGmeMsHSxupsg" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
